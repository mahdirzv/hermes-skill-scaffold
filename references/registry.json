{
  "version": "0.4.11",
  "min_scaffold_py_version": "0.1.0",
  "_note": "v0.4.11: nextjs base → v0.1.12, kmp base → v0.1.4. Starter-identity files (LICENSE, README.md, SECURITY.md) are no longer copied verbatim into scaffolded projects — starters declare remove_on_scaffold + generate_readme in .scaffold.json, so consumer projects get a project-specific README with {{project_name}} expanded instead of inheriting the starter's attribution. Tags are immutable — safe to cache indefinitely.",
  "stack_defaults": {
    "kmp": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    },
    "nextjs": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    }
  },
  "packs": [
    {
      "id": "kmp_base",
      "stack": "kmp",
      "kind": "base",
      "source": "git+https://github.com/mahdirzv/kmp-starter-project@v0.1.4",
      "verify": [
        ["./gradlew", "--no-daemon", "build"]
      ]
    },
    {
      "id": "kmp_auth",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_ui_theme",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_room",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_ci",
      "stack": "kmp",
      "kind": "infra"
    },
    {
      "id": "nextjs_base",
      "stack": "nextjs",
      "kind": "base",
      "source": "git+https://github.com/mahdirzv/base-next-starter@v0.1.12",
      "verify": [
        [
          "pnpm",
          "install",
          "--frozen-lockfile"
        ],
        [
          "pnpm",
          "build"
        ]
      ]
    },
    {
      "id": "nextjs_auth",
      "stack": "nextjs",
      "kind": "feature"
    },
    {
      "id": "nextjs_ui_theme",
      "stack": "nextjs",
      "kind": "feature"
    },
    {
      "id": "nextjs_ci",
      "stack": "nextjs",
      "kind": "infra"
    }
  ]
}
