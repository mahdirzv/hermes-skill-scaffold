{
  "version": "0.4.7",
  "min_scaffold_py_version": "0.1.0",
  "_note": "v0.4.7: nextjs base → v0.1.10 (firebase/custom stub providers now redirect protected routes to /sign-in instead of crashing /dashboard with a 500; stale src/modules/ paths swept from user-visible UI and warnings; dead types/exports removed; Clerk toUser type derived from SDK). KMP base → v0.1.3 (iOS PRODUCT_BUNDLE_IDENTIFIER now renamed — Config.xcconfig was shipping with demo `com.example.kmpstarterproject`, missed by every prior scaffold). Tags are immutable — safe to cache indefinitely.",
  "stack_defaults": {
    "kmp": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    },
    "nextjs": {
      "auth_provider": "clerk",
      "theme_preset": "neutral"
    }
  },
  "packs": [
    {
      "id": "kmp_base",
      "stack": "kmp",
      "kind": "base",
      "source": "git+https://github.com/mahdirzv/kmp-starter-project@v0.1.3",
      "verify": [
        ["./gradlew", "--no-daemon", "build"]
      ]
    },
    {
      "id": "kmp_auth",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_ui_theme",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_room",
      "stack": "kmp",
      "kind": "feature"
    },
    {
      "id": "kmp_ci",
      "stack": "kmp",
      "kind": "infra"
    },
    {
      "id": "nextjs_base",
      "stack": "nextjs",
      "kind": "base",
      "source": "git+https://github.com/mahdirzv/base-next-starter@v0.1.10",
      "verify": [
        [
          "pnpm",
          "install",
          "--frozen-lockfile"
        ],
        [
          "pnpm",
          "build"
        ]
      ]
    },
    {
      "id": "nextjs_auth",
      "stack": "nextjs",
      "kind": "feature"
    },
    {
      "id": "nextjs_ui_theme",
      "stack": "nextjs",
      "kind": "feature"
    },
    {
      "id": "nextjs_ci",
      "stack": "nextjs",
      "kind": "infra"
    }
  ]
}
